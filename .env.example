# Detective - Farcaster Mini App
# REQUIRED ENVIRONMENT VARIABLES

# ============================================
# CRITICAL: API SERVICES (REQUIRED)
# ============================================

# Neynar API - For Farcaster user data and validation
# Get your API key at: https://neynar.com/app/api-keys
NEYNAR_API_KEY=your_neynar_api_key_here

# Venice AI API - For bot intelligence and writing style analysis
# Get your API key at: https://venice.ai/settings/api
VENICE_API_KEY=your_venice_api_key_here

# Netmind AI API - For additional LLM models (Llama 3.3 70B, etc.)
# Get your API key at: https://www.netmind.ai
# Free tier available with good rate limits
NETMIND_API_KEY=your_netmind_api_key_here

# OpenRouter API - For multi-LLM support (Claude, Gemini, etc.)
# Get your API key at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ============================================
# CRITICAL: REDIS (REQUIRED)
# ============================================

# Upstash Redis (Recommended for Vercel/Serverless)
# Get a free instance at: https://upstash.com
# REST API works perfectly with serverless functions
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ============================================
# CRITICAL: DATABASE (REQUIRED)
# ============================================

# PostgreSQL - For match history, player stats, and leaderboards
# Get a free instance at: https://neon.tech or https://supabase.com
# Format: postgresql://[user][:password]@[host][:port]/[database]
DATABASE_URL=postgresql://localhost:5432/detective

# ============================================
# BLOCKCHAIN (OPTIONAL)
# ============================================

# Arbitrum Transaction Gating (for registration with TX proof)
# Enable by setting to 'true' - default: false for dev
NEXT_PUBLIC_ARBITRUM_ENABLED=false

# Arbitrum Entry Contract Address
# Verifies player registration via on-chain transaction
# Deployed: 0xF3f9e93B0bdd7C87B261F30eC6a697fAf50f4460
# Verified: https://arbiscan.io/address/0xF3f9e93B0bdd7C87B261F30eC6a697fAf50f4460
NEXT_PUBLIC_ARBITRUM_ENTRY_CONTRACT=0xF3f9e93B0bdd7C87B261F30eC6a697fAf50f4460

# Minimum entry fee in wei (0 for free registration with TX proof)
NEXT_PUBLIC_ARBITRUM_MIN_FEE=0

# Arbitrum RPC URL (for transaction verification)
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ============================================
# WALLET INTEGRATION (OPTIONAL)
# ============================================

# WalletConnect Project ID - For mobile wallet connections
# Get at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ============================================
# x402 AGENT PAYMENTS (OPTIONAL)
# ============================================

# Enable x402 pay-per-request for agent API endpoints
# When enabled, agents must pay USDC per API call
NEXT_PUBLIC_X402_ENABLED=false

# x402 Facilitator URL for payment verification
# Default: Coinbase CDP facilitator
X402_FACILITATOR_URL=https://x402.org/facilitator

# USDC payment receiving address (your wallet)
# Required when X402_ENABLED=true
X402_PAYMENT_ADDRESS=0xYourPaymentAddressHere

# ============================================
# WORLD ID 4.0 (For PL_Genesis Hackathon - World Bounty)
# ============================================

# World ID App ID - Get from https://developer.world.org
# Format: app_xxxxxxxx
NEXT_PUBLIC_WORLD_APP_ID=your_world_app_id_here

# World ID RP ID - Get from https://developer.world.org
# Format: rp_xxxxxxxx
NEXT_PUBLIC_WORLD_RP_ID=your_world_rp_id_here

# World ID RP Signing Key - Keep secret, used for server-side signatures
# Get from Developer Portal > Your App > RP Signing Key
WORLD_RP_SIGNING_KEY=your_rp_signing_key_here

# ============================================
# STORACHA DECENTRALIZED STORAGE (OPTIONAL - PL_Genesis Sponsor Bounty)
# ============================================

# Enable Storacha integration for verifiable game provenance
# Stores bot training data, match history, and game snapshots on IPFS/Filecoin
STORACHA_ENABLED=false

# Storacha Space DID - your decentralized storage namespace
# Create with: storacha space create detective-game
# Get with: storacha space info
STORACHA_SPACE_DID=did:key:your_space_did_here

# ============================================
# MACHINE PAYMENTS PROTOCOL (MPP) - TEMPO (OPTIONAL)
# ============================================

# Enable MPP for agent-to-agent payments via Tempo blockchain
# Optimization Arena hackathon participants have $20 Tempo credit
# Docs: https://mpp.dev/overview | https://docs.tempo.xyz/
MPP_ENABLED=false

# Your Tempo wallet address for receiving payments
# Create with: npx mppx account create
MPP_WALLET_ADDRESS=0xYourTempoWalletAddressHere

# Tempo RPC endpoint (default: mainnet)
TEMPO_RPC_URL=https://rpc.tempo.xyz

# ============================================
# MACHINE PAYMENTS PROTOCOL (MPP) - STELLAR (OPTIONAL)
# ============================================

# Enable MPP for agent-to-agent payments via Stellar blockchain
# Fast settlement (~5s), low fees (~$0.00001), native USDC support
# Docs: https://developers.stellar.org/docs | https://github.com/stellar/stellar-mpp-sdk
STELLAR_MPP_ENABLED=false

# Your Stellar wallet address for receiving payments (G... format)
# Create with Freighter wallet or stellar-sdk
STELLAR_WALLET_ADDRESS=GYourStellarWalletAddressHere

# Stellar Horizon API endpoint
# Testnet: https://horizon-testnet.stellar.org
# Mainnet: https://horizon.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar network (TESTNET or PUBLIC)
STELLAR_NETWORK=TESTNET

# ============================================
# SECURITY (OPTIONAL)
# ============================================

# Cron job secret for state transition endpoint
# Set this to secure /api/cron/tick endpoint
CRON_SECRET=your_random_secret_here

# ============================================
